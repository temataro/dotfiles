# rose-pine dunst notifications. Deploys to ~/.config/dunst/dunstrc.
# Matches nvim + i3 + tmux + rofi. Reload: `pkill dunst` (respawns on next notify).

[global]
    monitor = 0
    follow = mouse
    width = 340
    height = (0, 200)
    origin = top-right
    offset = (12, 12)
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 320

    indicate_hidden = yes
    transparency = 8
    separator_height = 2
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 2
    frame_color = "#c4a7e7"
    gap_size = 6
    separator_color = frame
    corner_radius = 12

    sort = yes
    font = JetBrainsMono Nerd Font 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    enable_recursive_icon_lookup = true

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#191724"
    foreground = "#908caa"
    frame_color = "#31748f"
    timeout = 6

[urgency_normal]
    background = "#191724"
    foreground = "#e0def4"
    frame_color = "#c4a7e7"
    timeout = 8

[urgency_critical]
    background = "#191724"
    foreground = "#e0def4"
    frame_color = "#eb6f92"
    timeout = 0
