# Ghostty Configuration
# Generated by Ventz's Ghostty Settings Generator
# https://github.com/ventz/ghostty-settings-visual-config

# Typography

# Synthesize bold/italic if unavailable
# Options: true, false, no-bold, no-italic
font-synthetic-style = true

# Theme + Background

# Theme
theme = "Gruvbox Dark"

# Background opacity
# Options: 0.0 to 1.0
background-opacity = 0.4

# Apply background opacity to cells with explicit background colors.
# Helps transparency work in apps like Neovim/tmux that paint their own background.
background-opacity-cells = true

# Background blur intensity
# Options: false/true or number
background-blur = 10

# Window + UI

# Start fullscreen
# Options: Boolean
fullscreen = true

# Window decorations
# Options: auto, none, client, server
window-decoration = server

# Window theme (overall light/dark behavior)
window-theme = ghostty

# Window padding (in points)
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

# Padding area color
# Options: background, extend, extend-always
window-padding-color = extend

# Enable VSync
# Options: Boolean
window-vsync = true

# Confirm before closing
# Options: Boolean
confirm-close-surface = false

# Tabs + Splits

# Preserve split zoom while navigating between splits.
split-preserve-zoom = navigation

# Cursor + Mouse

# Hide mouse cursor when typing.
mouse-hide-while-typing = true

# Allow clicking at prompts to move the cursor (requires shell integration / OSC 133).
cursor-click-to-move = true

# Scrollback

# Scrollback buffer size in bytes (includes the active screen).
scrollback-limit = 104857600

# Clipboard

# Allow clipboard read
# Options: ask, allow, deny
clipboard-read = allow

# Allow clipboard write
# Options: ask, allow, deny
clipboard-write = allow

# Copy on selection
copy-on-select = clipboard

# Trim spaces when copying
# Options: Boolean
clipboard-trim-trailing-spaces = true

# Notifications

# Allow desktop notifications
# Options: Boolean
desktop-notifications = true

# Notify when long-running commands finish in an unfocused surface.
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 10s

# Platform: macOS

# Enable window shadow
# Options: Boolean
macos-window-shadow = true

# Auto secure keyboard input
# Options: Boolean
macos-auto-secure-input = true

# Show secure input indicator
# Options: Boolean
macos-secure-input-indication = true

# Platform: GTK

# Tab bar location
# Options: top, bottom, hidden
gtk-tabs-location = hidden

# Wide tabs
# Options: Boolean
gtk-wide-tabs = true

# Show GTK titlebar
# Options: Boolean
gtk-titlebar = false

# Single-instance behavior
gtk-single-instance = desktop

# Quick Terminal

# Auto-hide on focus lost
# Options: Boolean
quick-terminal-autohide = true

# Keybindings

# Format: trigger=action
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+r=reload_config

# Common UI
keybind = ctrl+shift+f=search
keybind = ctrl+shift+p=toggle_command_palette
keybind = ctrl+shift+backquote=toggle_quick_terminal

# Tabs
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab
keybind = ctrl+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab

# Splits
keybind = ctrl+shift+d=new_split:right
keybind = ctrl+shift+s=new_split:down
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+enter=toggle_split_zoom
keybind = ctrl+shift+q=close_surface

# Convenience toggles
keybind = ctrl+shift+m=toggle_mouse_reporting
keybind = ctrl+shift+o=toggle_background_opacity

# Font size (use physical key codes to avoid layout issues)
keybind = ctrl+shift+equal=increase_font_size
keybind = ctrl+shift+minus=decrease_font_size
keybind = ctrl+shift+digit_0=reset_font_size

# Local overrides (optional, not tracked)
config-file = ?config.local
