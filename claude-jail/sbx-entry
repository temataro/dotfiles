#!/usr/bin/env bash
# Sandbox entry banner — shown for ~1s on entering the container, then cleared
# before the real command (Claude, or a shell override) takes over.
set -e

printf '\033[1;33m'                       # bold amber
cat <<'BANNER'

     ____                 _ _
    / ___|  __ _ _ __   __| | |__   _____  __
    \___ \ / _` | '_ \ / _` | '_ \ / _ \ \/ /
     ___) | (_| | | | | (_| | |_) | (_) >  <
    |____/ \__,_|_| |_|\__,_|_.__/ \___/_/\_\

BANNER
printf '\033[0;90m'                        # dim grey subtitle
printf '    jailed to mounted repo  ·  other host files hidden  ·  skip-perms on\n'
printf '\033[0m\n'

sleep 1
printf '\033c'                             # full reset — wipes the banner

exec "$@"
